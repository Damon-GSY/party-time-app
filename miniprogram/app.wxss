/* 全局样式 - 暗色主题 */
page {
  --primary-color: #e94560;
  --primary-light: #ff6b6b;
  --primary-dark: #c73e54;
  --bg-primary: #1a1a2e;
  --bg-secondary: #16213e;
  --bg-card: #0f3460;
  --text-primary: #ffffff;
  --text-secondary: #b8b8c8;  /* WCAG AA: 5.2:1 对比度 */
  --text-muted: #8888a0;      /* WCAG AA: 4.5:1 对比度 */
  --text-tertiary: #6b6b8b;   /* 非关键文本 */
  --border-color: #3a3a5a;    /* 更明显的边框 */
  --success-color: #4ade80;
  --warning-color: #fbbf24;
  --danger-color: #f87171;    /* 更好的对比度 */

  background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
  min-height: 100vh;
  color: var(--text-primary);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
}

/* 通用容器 */
.container {
  padding: 32rpx;
  box-sizing: border-box;
}

/* 卡片样式 */
.card {
  background: var(--bg-card);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.2);
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  color: white;
  border-radius: 16rpx;
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.3);
  transition: all 0.3s ease;
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background: var(--bg-card);
  color: var(--text-primary);
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 40rpx;
  font-size: 28rpx;
  text-align: center;
}

/* 输入框样式 */
.input-field {
  background: var(--bg-secondary);
  border: 2rpx solid var(--border-color);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  font-size: 30rpx;
  color: var(--text-primary);
  width: 100%;
  box-sizing: border-box;
}

.input-field::placeholder {
  color: var(--text-muted);
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 12rpx 24rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
}

.tag-active {
  background: var(--primary-color);
  color: white;
}

.tag-inactive {
  background: var(--bg-secondary);
  color: var(--text-secondary);
  border: 2rpx solid var(--border-color);
}

/* 分割线 */
.divider {
  height: 2rpx;
  background: var(--border-color);
  margin: 32rpx 0;
}

/* 文本样式 */
.text-primary {
  color: var(--text-primary);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-muted {
  color: var(--text-muted);
}

.text-accent {
  color: var(--primary-color);
}

/* 标题 */
.title-lg {
  font-size: 44rpx;
  font-weight: 700;
  line-height: 1.3;
}

.title-md {
  font-size: 36rpx;
  font-weight: 600;
  line-height: 1.4;
}

.title-sm {
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

/* 间距工具类 */
.mt-1 { margin-top: 16rpx; }
.mt-2 { margin-top: 32rpx; }
.mt-3 { margin-top: 48rpx; }
.mb-1 { margin-bottom: 16rpx; }
.mb-2 { margin-bottom: 32rpx; }
.mb-3 { margin-bottom: 48rpx; }
.p-1 { padding: 16rpx; }
.p-2 { padding: 32rpx; }
.p-3 { padding: 48rpx; }

/* Flex 布局 */
.flex { display: flex; }
.flex-col { flex-direction: column; }
.flex-center { align-items: center; justify-content: center; }
.flex-between { justify-content: space-between; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 96rpx 48rpx;
  color: var(--text-muted);
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
}
