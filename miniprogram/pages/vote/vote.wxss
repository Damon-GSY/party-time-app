/* 投票页面样式 - 精致动画版 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  padding-bottom: 160rpx;
}

/* 淡入动画 */
.fade-in {
  animation: fadeInUp 0.5s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 加载状态 */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-animation {
  position: relative;
  width: 120rpx;
  height: 120rpx;
}

.loading-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-ring:nth-child(2) {
  width: 80%;
  height: 80%;
  top: 10%;
  left: 10%;
  border-top-color: var(--primary-light);
  animation-duration: 0.8s;
  animation-direction: reverse;
}

.loading-ring:nth-child(3) {
  width: 60%;
  height: 60%;
  top: 20%;
  left: 20%;
  border-top-color: #fff;
  animation-duration: 0.6s;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 过期状态 */
.expired-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 48rpx;
}

.expired-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
  animation: shake 2s ease-in-out infinite;
}

@keyframes shake {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.expired-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 16rpx;
}

.expired-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 48rpx;
}

.view-result-btn {
  padding: 24rpx 64rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #fff;
  border: none;
}

/* 头部信息 */
.header-section {
  padding: 32rpx;
}

.event-info {
  display: flex;
  flex-direction: column;
}

.event-name {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 16rpx;
}

.event-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.event-note {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

/* 昵称输入 */
.nickname-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 28rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  border-color: var(--primary-color);
  background: rgba(15, 52, 96, 0.7);
}

.input-label {
  font-size: 28rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.nickname-input {
  flex: 1;
  font-size: 28rpx;
  color: #fff;
}

.nickname-input.has-value {
  color: var(--primary-light);
}

/* 提示 */
.tip-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.tip-card {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 24rpx;
  background: rgba(251, 191, 36, 0.1);
  border-radius: 16rpx;
  border: 2rpx solid rgba(251, 191, 36, 0.2);
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #FED81F;
}

/* 日期切换 */
.date-tabs {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.date-scroll {
  width: 100%;
  white-space: nowrap;
}

.date-tabs-inner {
  display: inline-flex;
  gap: 16rpx;
  padding: 8rpx 0;
}

.date-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  background: rgba(15, 52, 96, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.date-tab:active {
  transform: scale(0.95);
}

.date-tab.active {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-color: transparent;
  transform: scale(1.05);
}

.tab-weekday {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 4rpx;
  transition: color 0.3s ease;
}

.date-tab.active .tab-weekday {
  color: rgba(255, 255, 255, 0.8);
}

.tab-date {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* 时段操作按钮 - 移到网格上方 */
.slot-actions {
  padding: 0 32rpx;
  margin-bottom: 16rpx;
}

.action-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.day-selector {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.day-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.day-date {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.quick-actions {
  display: flex;
  gap: 16rpx;
}

.quick-btn {
  padding: 12rpx 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  transition: all 0.2s ease;
}

.quick-btn:active {
  transform: scale(0.95);
}

.quick-btn.select-all {
  background: rgba(74, 222, 128, 0.15);
  color: #4ade80;
}

.quick-btn.clear {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

/* 时段网格 */
.slots-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

/* 日期切换过渡 */
.slots-grid.grid-hidden {
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.15s ease;
}

.slots-grid.grid-visible {
  opacity: 1;
  transition: opacity 0.15s ease;
}

.time-axis {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  margin-bottom: 12rpx;
  padding: 0 4rpx;
}

.time-axis.time-axis-4 {
  grid-template-columns: repeat(4, 1fr);
}

.time-label {
  text-align: center;
  font-size: 22rpx;
  color: var(--text-muted);
  font-weight: 500;
}

.slots-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 12rpx;
  padding: 8rpx 0;
}

/* 12个时段 - 2行6列 */
.slots-grid.slots-12 {
  grid-template-columns: repeat(6, 1fr);
}

/* 24个时段 - 4行6列 */
.slots-grid.slots-24 {
  grid-template-columns: repeat(6, 1fr);
}

/* 4个时段 - 1行4列 */
.slots-grid.slots-4 {
  grid-template-columns: repeat(4, 1fr);
}

.slot-cell {
  height: 88rpx;
  min-height: 88rpx;
  background: rgba(15, 52, 96, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 16rpx;
  position: relative;
  animation: slotFadeIn 0.4s ease forwards;
  opacity: 0;
  transition: all 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

@keyframes slotFadeIn {
  from {
    opacity: 0;
    transform: scale(0.8);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.slot-inner {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.slot-time {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.slot-cell.selected .slot-time {
  color: #fff;
}

.slot-cell-hover {
  transform: scale(0.95);
  background: rgba(83, 87, 169, 0.2);
}

.slot-cell.selected {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(83, 87, 169, 0.5), inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
  transform: scale(1.02);
  transition: all 0.3s ease;
}

/* 选中动画：scale 1.0 -> 1.15 -> 1.0 */
@keyframes slotSelect {
  0% { transform: scale(1.0); }
  40% { transform: scale(1.15); }
  100% { transform: scale(1.0); }
}

/* 取消选中动画：scale 1.0 -> 0.9 -> 1.0 */
@keyframes slotDeselect {
  0% { transform: scale(1.0); }
  40% { transform: scale(0.9); }
  100% { transform: scale(1.0); }
}

.slot-cell.anim-select {
  animation: slotSelect 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.slot-cell.anim-deselect {
  animation: slotDeselect 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.slot-cell.partial {
  background: linear-gradient(135deg, rgba(83, 87, 169, 0.3), rgba(123, 127, 204, 0.2));
  border-color: rgba(83, 87, 169, 0.3);
}

.slot-check {
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: checkPop 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

@keyframes checkPop {
  0% {
    transform: scale(0) rotate(-45deg);
  }
  50% {
    transform: scale(1.3) rotate(10deg);
  }
  100% {
    transform: scale(1) rotate(0deg);
  }
}

.check-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: bold;
}

/* 选择统计 */
.selection-summary {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.summary-left {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.summary-label {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.summary-count {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--primary-light);
  transition: transform 0.3s ease;
}

.summary-count.animated {
  animation: countPop 0.3s ease;
}

@keyframes countPop {
  0% { transform: scale(1); }
  50% { transform: scale(1.2); }
  100% { transform: scale(1); }
}

.summary-unit {
  font-size: 24rpx;
  color: var(--text-muted);
}

/* 提交按钮 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(26, 26, 46, 0.98), transparent);
}

.submit-btn {
  width: 100%;
  height: 108rpx;
  background: rgba(107, 107, 107, 0.3);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.submit-btn::after {
  display: none;
}

.submit-btn.has-selection {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  box-shadow: 0 12rpx 40rpx rgba(83, 87, 169, 0.4);
}

.submit-btn.has-selection:active {
  transform: scale(0.96);
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.btn-icon {
  font-size: 32rpx;
}

.btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.btn-loading {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 30rpx;
  color: #fff;
}

.spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 成功弹窗 - 精致版带粒子 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.success-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.modal-content {
  position: relative;
  width: 600rpx;
  padding: 64rpx 48rpx;
  background: var(--bg-card);
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  transform: translateY(100%);
  transition: transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.4);
}

.success-modal.show .modal-content {
  transform: translateY(0);
}

/* 粒子效果 */
.confetti-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
  pointer-events: none;
}

.confetti {
  position: absolute;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  animation: confetti-fall 2s ease-out forwards;
}

.confetti.c1 { background: #7B7FCC; left: 10%; animation-delay: 0s; }
.confetti.c2 { background: #FED81F; left: 20%; animation-delay: 0.1s; }
.confetti.c3 { background: #4ade80; left: 30%; animation-delay: 0.15s; }
.confetti.c4 { background: #60a5fa; left: 40%; animation-delay: 0.05s; }
.confetti.c5 { background: #f472b6; left: 50%; animation-delay: 0.2s; }
.confetti.c6 { background: #a78bfa; left: 60%; animation-delay: 0.1s; }
.confetti.c7 { background: #fb923c; left: 70%; animation-delay: 0.15s; }
.confetti.c8 { background: #2dd4bf; left: 80%; animation-delay: 0.05s; }
.confetti.c9 { background: #5357A9; left: 15%; animation-delay: 0.25s; }
.confetti.c10 { background: #FED81F; left: 45%; animation-delay: 0.2s; }
.confetti.c11 { background: #4ade80; left: 75%; animation-delay: 0.12s; }
.confetti.c12 { background: #60a5fa; left: 90%; animation-delay: 0.18s; }

/* 新增粒子 c13-c20：不同形状和轨迹 */
.confetti.c13 { background: #f472b6; left: 5%; animation-delay: 0.08s; animation-duration: 2.5s; border-radius: 2rpx; width: 20rpx; height: 10rpx; }
.confetti.c14 { background: #FED81F; left: 25%; animation-delay: 0.22s; animation-duration: 1.8s; border-radius: 2rpx; width: 10rpx; height: 20rpx; }
.confetti.c15 { background: #a78bfa; left: 35%; animation-delay: 0.05s; animation-duration: 2.2s; }
.confetti.c16 { background: #fb923c; left: 55%; animation-delay: 0.28s; animation-duration: 2.8s; border-radius: 2rpx; width: 18rpx; height: 12rpx; }
.confetti.c17 { background: #2dd4bf; left: 65%; animation-delay: 0.15s; animation-duration: 1.6s; }
.confetti.c18 { background: #5357A9; left: 85%; animation-delay: 0.3s; animation-duration: 2.4s; border-radius: 2rpx; width: 14rpx; height: 14rpx; }
.confetti.c19 { background: #60a5fa; left: 12%; animation-delay: 0.2s; animation-duration: 2.1s; }
.confetti.c20 { background: #4ade80; left: 48%; animation-delay: 0.1s; animation-duration: 1.9s; border-radius: 2rpx; width: 12rpx; height: 18rpx; }

@keyframes confetti-fall {
  0% {
    top: 0;
    transform: translateY(0) rotate(0deg);
    opacity: 1;
  }
  100% {
    top: 100%;
    transform: translateY(600rpx) rotate(720deg);
    opacity: 0;
  }
}

.success-animation {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 32rpx;
}

.checkmark-circle {
  width: 100%;
  height: 100%;
  border: 6rpx solid var(--primary-color);
  border-radius: 50%;
  animation: circleIn 0.5s ease forwards;
}

@keyframes circleIn {
  from {
    transform: scale(0);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

/* SVG 对号动画 */
.checkmark-svg {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 120rpx;
  height: 120rpx;
}

.checkmark-svg-path {
  width: 100%;
  height: 100%;
}

.checkmark-svg-circle {
  stroke-dasharray: 166;
  stroke-dashoffset: 166;
  animation: svgCircleIn 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
}

.checkmark-svg-check {
  stroke-dasharray: 48;
  stroke-dashoffset: 48;
  animation: svgCheckDraw 0.4s cubic-bezier(0.65, 0, 0.45, 1) 0.45s forwards;
}

@keyframes svgCircleIn {
  0% { stroke-dashoffset: 166; }
  100% { stroke-dashoffset: 0; }
}

@keyframes svgCheckDraw {
  0% { stroke-dashoffset: 48; }
  100% { stroke-dashoffset: 0; }
}

/* 隐藏旧的 checkmark 伪元素（已被 SVG 替代） */
.checkmark {
  display: none;
}

.success-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: var(--text-secondary);
  margin-bottom: 40rpx;
  text-align: center;
}

.modal-actions {
  display: flex;
  gap: 24rpx;
  width: 100%;
}

.modal-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  transition: all 0.2s ease;
}

.modal-btn:active {
  transform: scale(0.98);
}

.modal-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  color: var(--text-primary);
}

.modal-btn.primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
}

/* 开启提醒按钮 */
.subscribe-row {
  margin-top: 24rpx;
  width: 100%;
}

.subscribe-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
  transition: all 0.2s;
}

.subscribe-btn:active {
  background: rgba(255, 255, 255, 0.12);
  transform: scale(0.98);
}

.subscribe-btn::after {
  border: none;
}

.subscribe-icon {
  margin-right: 8rpx;
  font-size: 28rpx;
}

.subscribe-text {
  color: var(--text-secondary);
}

/* ===== Hero UI / Aceternity 升级 ===== */

/* Glass Slot 格子 */
.glass-slot {
  background: rgba(15, 52, 96, 0.35);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}
.glass-slot.selected {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 24rpx rgba(83, 87, 169, 0.5), inset 0 1rpx 0 rgba(255, 255, 255, 0.2);
}

/* Ripple 波纹 */
.ripple-container {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  overflow: hidden;
  border-radius: 16rpx;
  z-index: 5;
}
.ripple-wave {
  position: absolute;
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.4), transparent 70%);
  transform: translate(-50%, -50%) scale(0);
  animation: ripple-expand 0.6s ease-out forwards;
}
@keyframes ripple-expand {
  to { transform: translate(-50%, -50%) scale(12); opacity: 0; }
}

/* 进度条 */
.counter-progress {
  width: 100%;
  height: 4rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 100rpx;
  margin-top: 12rpx;
  overflow: hidden;
}
.counter-progress-bar {
  height: 100%;
  background: linear-gradient(90deg, var(--primary-color), var(--primary-light));
  border-radius: 100rpx;
  transition: width 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  box-shadow: 0 0 8rpx rgba(83, 87, 169, 0.4);
}

/* 增强 Glass Modal */
.glass-modal {
  background: rgba(15, 52, 96, 0.6);
  backdrop-filter: blur(30rpx);
  -webkit-backdrop-filter: blur(30rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

/* Success Beam */
.success-beam {
  position: absolute;
  width: 100%;
  height: 2rpx;
  left: 0;
  background: linear-gradient(90deg, transparent, rgba(83, 87, 169, 0.6), transparent);
  animation: success-beam-flash 1.5s ease-out infinite;
  pointer-events: none;
  z-index: 0;
}
@keyframes success-beam-flash {
  0% { transform: scaleX(0); opacity: 0; }
  50% { transform: scaleX(1); opacity: 1; }
  100% { transform: scaleX(1.5); opacity: 0; }
}

/* Modal Meteor */
.modal-meteor {
  position: absolute;
  width: 3rpx;
  height: 100rpx;
  background: linear-gradient(to bottom, rgba(255, 255, 255, 0.6), transparent);
  border-radius: 100rpx;
  animation: modal-meteor-fall linear infinite;
  pointer-events: none;
  z-index: 0;
}
.modal-meteor:nth-child(4) { left: 10%; animation-duration: 2s; animation-delay: 0s; }
.modal-meteor:nth-child(5) { left: 50%; animation-duration: 2.5s; animation-delay: 0.5s; }
.modal-meteor:nth-child(6) { left: 85%; animation-duration: 2.2s; animation-delay: 1s; }
@keyframes modal-meteor-fall {
  0% { transform: translateY(-120rpx) rotate(-30deg); opacity: 0; }
  10% { opacity: 1; }
  80% { opacity: 0.4; }
  100% { transform: translateY(800rpx) rotate(-30deg); opacity: 0; }
}
