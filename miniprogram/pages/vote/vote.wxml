<!--投票页面 - 三态偏好版-->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-screen" wx:if="{{loading}}">
    <view class="loading-animation">
      <view class="loading-ring"></view>
      <view class="loading-ring"></view>
      <view class="loading-ring"></view>
    </view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 过期状态 -->
  <view class="expired-screen" wx:elif="{{expired}}">
    <view class="expired-icon">⏰</view>
    <text class="expired-title">活动已过期</text>
    <text class="expired-desc">该聚会投票已结束</text>
    <button class="view-result-btn" bindtap="goToResult">查看结果</button>
  </view>

  <!-- 主内容 -->
  <block wx:else>
    <!-- 头部信息 -->
    <view class="header-section fade-in">
      <view class="event-info">
        <text class="event-name">{{event.name}}</text>
        <view class="event-meta">
          <text class="meta-item">📅 {{event.dateRangeText}}</text>
          <text class="meta-item">👥 {{participantCount}}人已填</text>
        </view>
        <text class="event-note" wx:if="{{event.note}}">{{event.note}}</text>
      </view>
    </view>

    <!-- 昵称输入 -->
    <view class="nickname-section fade-in" style="animation-delay: 0.1s;">
      <view class="input-wrapper">
        <text class="input-label">你的昵称</text>
        <input
          class="nickname-input {{nickname ? 'has-value' : ''}}"
          placeholder="使用微信昵称"
          value="{{nickname}}"
          bindinput="onNicknameInput"
          maxlength="10"
        />
      </view>
    </view>

    <!-- 提示 -->
    <view class="tip-section fade-in" style="animation-delay: 0.15s;">
      <view class="tip-card">
        <text class="tip-icon">💡</text>
        <text class="tip-text">点击选择：有空 → 勉强 → 取消</text>
      </view>
    </view>

    <!-- 日期切换 -->
    <view class="date-tabs fade-in" style="animation-delay: 0.2s;" wx:if="{{dates.length > 1}}">
      <scroll-view scroll-x class="date-scroll">
        <view class="date-tabs-inner">
          <view
            class="date-tab {{currentDateIndex === index ? 'active' : ''}}"
            wx:for="{{dates}}"
            wx:key="date"
            bindtap="switchDate"
            data-index="{{index}}"
          >
            <text class="tab-weekday">{{item.weekday}}</text>
            <text class="tab-date">{{item.day}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <!-- 选择操作按钮 -->
    <view class="slot-actions fade-in" style="animation-delay: 0.22s;">
      <view class="action-row">
        <view class="day-selector">
          <text class="day-label">{{dates[currentDateIndex].weekday}}</text>
          <text class="day-date">{{dates[currentDateIndex].date}}</text>
        </view>
        <view class="quick-actions">
          <view class="quick-btn select-all" bindtap="selectAll">
            <text>全天有空</text>
          </view>
          <view class="quick-btn clear" bindtap="clearSelection" wx:if="{{availableCount + reluctantCount > 0}}">
            <text>清空</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 时段网格 -->
    <view class="slots-section fade-in" style="animation-delay: 0.25s;">
      <!-- 时间轴 -->
      <view class="time-axis time-axis-{{slotsPerDay}}">
        <view class="time-label" wx:for="{{timeLabels}}" wx:key="*this">{{item}}</view>
      </view>

      <!-- 时段格子 - 三态 -->
      <view class="slots-grid slots-{{slotsPerDay}} {{gridVisible ? 'grid-visible' : 'grid-hidden'}}">
        <view
          class="slot-cell glass-slot {{item.score === 2 ? 'state-available' : ''}} {{item.score === 1 ? 'state-reluctant' : ''}} {{animatingSlotIndex === index && animatingSlotAction === 'select' ? 'anim-select' : ''}} {{animatingSlotIndex === index && animatingSlotAction === 'deselect' ? 'anim-deselect' : ''}}"
          wx:for="{{currentSlots}}"
          wx:key="id"
          bindtap="toggleSlot"
          data-index="{{index}}"
          hover-class="slot-cell-hover"
          style="animation-delay: {{0.02 * index}}s;"
        >
          <!-- Ripple -->
          <view class="ripple-container" wx:if="{{item.rippleShow}}">
            <view class="ripple-wave" style="left: {{item.rippleX}}px; top: {{item.rippleY}}px;"></view>
          </view>
          <view class="slot-inner">
            <text class="slot-time">{{item.timeLabel}}</text>
            <!-- 有空标记 -->
            <view class="slot-icon" wx:if="{{item.score === 2}}">
              <text class="icon-mark">✓</text>
            </view>
            <!-- 勉强标记 -->
            <view class="slot-icon" wx:if="{{item.score === 1}}">
              <text class="icon-mark icon-wave">~</text>
            </view>
          </view>
          <!-- 浮现状态文字 -->
          <view class="floating-label {{floatingSlotIndex === index ? 'show' : ''}}" wx:if="{{floatingSlotIndex === index}}">
            <text>{{floatingText}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 已选统计 - 双色 -->
    <view class="selection-summary fade-in" style="animation-delay: 0.3s;">
      <view class="summary-row">
        <view class="summary-stat">
          <text class="stat-dot dot-green"></text>
          <text class="stat-num">{{availableCount}}</text>
          <text class="stat-label">个有空</text>
        </view>
        <text class="stat-divider" wx:if="{{reluctantCount > 0}}">·</text>
        <view class="summary-stat" wx:if="{{reluctantCount > 0}}">
          <text class="stat-dot dot-yellow"></text>
          <text class="stat-num">{{reluctantCount}}</text>
          <text class="stat-label">个勉强</text>
        </view>
      </view>
      <view class="counter-progress">
        <view class="counter-progress-green" style="width: {{counterGreenPercent || 0}}%;"></view>
        <view class="counter-progress-yellow" style="width: {{counterYellowPercent || 0}}%;"></view>
      </view>
    </view>

    <!-- 提交按钮 -->
    <view class="submit-section fade-in" style="animation-delay: 0.35s;">
      <button
        class="submit-btn {{submitting ? 'submitting' : ''}} {{availableCount + reluctantCount > 0 ? 'has-selection' : ''}}"
        bindtap="handleSubmit"
        disabled="{{submitting}}"
      >
        <view class="btn-content" wx:if="{{!submitting}}">
          <text class="btn-icon">✨</text>
          <text class="btn-text">{{availableCount + reluctantCount > 0 ? '提交我的时间' : '请先选择时段'}}</text>
        </view>
        <view class="btn-loading" wx:else>
          <view class="spinner"></view>
          <text>提交中...</text>
        </view>
      </button>
    </view>

    <!-- 首次引导 Overlay -->
    <view class="guide-overlay {{showGuide ? 'show' : ''}}" catchtouchmove="preventMove">
      <view class="guide-backdrop" bindtap="closeGuide"></view>
      <view class="guide-content">
        <text class="guide-title">选择你的时间偏好</text>
        <view class="guide-steps">
          <!-- 步骤1：点击→有空 -->
          <view class="guide-step {{guideAnimStep >= 1 ? 'active' : ''}}">
            <view class="guide-demo-cell">
              <view class="guide-demo-inner {{guideAnimStep === 1 ? 'demo-available' : ''}}">✓</view>
            </view>
            <view class="guide-step-text">
              <text class="guide-step-label">点击一次</text>
              <text class="guide-step-desc">有空</text>
            </view>
          </view>
          <!-- 步骤2：再点→勉强 -->
          <view class="guide-step {{guideAnimStep >= 2 ? 'active' : ''}}">
            <view class="guide-demo-cell">
              <view class="guide-demo-inner {{guideAnimStep === 2 ? 'demo-reluctant' : ''}}">~</view>
            </view>
            <view class="guide-step-text">
              <text class="guide-step-label">再点一次</text>
              <text class="guide-step-desc">勉强可以</text>
            </view>
          </view>
          <!-- 步骤3：再点→取消 -->
          <view class="guide-step {{guideAnimStep >= 3 ? 'active' : ''}}">
            <view class="guide-demo-cell">
              <view class="guide-demo-inner {{guideAnimStep === 3 ? 'demo-empty' : ''}}"></view>
            </view>
            <view class="guide-step-text">
              <text class="guide-step-label">再点一次</text>
              <text class="guide-step-desc">取消选择</text>
            </view>
          </view>
        </view>
        <text class="guide-hint">不需要长按，不需要菜单，点就行</text>
        <view class="guide-btn" bindtap="closeGuide">
          <text>知道了</text>
        </view>
      </view>
    </view>

    <!-- 成功弹窗 -->
    <view class="success-modal {{showSuccess ? 'show' : ''}}" catchtouchmove="preventMove">
      <view class="modal-backdrop"></view>
      <!-- 粒子效果 -->
      <view class="confetti-container" wx:if="{{showSuccess}}">
        <view class="confetti c1"></view>
        <view class="confetti c2"></view>
        <view class="confetti c3"></view>
        <view class="confetti c4"></view>
        <view class="confetti c5"></view>
        <view class="confetti c6"></view>
        <view class="confetti c7"></view>
        <view class="confetti c8"></view>
        <view class="confetti c9"></view>
        <view class="confetti c10"></view>
        <view class="confetti c11"></view>
        <view class="confetti c12"></view>
        <view class="confetti c13"></view>
        <view class="confetti c14"></view>
        <view class="confetti c15"></view>
        <view class="confetti c16"></view>
        <view class="confetti c17"></view>
        <view class="confetti c18"></view>
        <view class="confetti c19"></view>
        <view class="confetti c20"></view>
      </view>
      <view class="modal-content glass-modal">
        <view class="success-beam" style="top: 30%;"></view>
        <view class="success-beam" style="top: 70%;"></view>
        <view class="modal-meteor"></view>
        <view class="modal-meteor"></view>
        <view class="modal-meteor"></view>
        <view class="success-animation">
          <view class="checkmark-circle"></view>
          <view class="checkmark-svg">
            <svg class="checkmark-svg-path" viewBox="0 0 52 52">
              <circle class="checkmark-svg-circle" cx="26" cy="26" r="24" fill="none" stroke="#e94560" stroke-width="2"/>
              <path class="checkmark-svg-check" fill="none" stroke="#e94560" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" d="M14 27l7 7 16-16"/>
            </svg>
          </view>
        </view>
        <text class="success-title">提交成功！</text>
        <view class="success-stats">
          <text class="success-stat green">{{successAvailable}} 个有空</text>
          <text class="success-stat yellow" wx:if="{{successReluctant > 0}}"> · {{successReluctant}} 个勉强</text>
        </view>
        <view class="modal-actions">
          <button class="modal-btn secondary" bindtap="goToResult">查看统计</button>
          <button class="modal-btn primary" bindtap="closeSuccess">继续修改</button>
        </view>
        <view class="subscribe-row" wx:if="{{!subscribeRequested}}">
          <button class="subscribe-btn" bindtap="requestSubscribe">
            <text class="subscribe-icon">🔔</text>
            <text class="subscribe-text">开启提醒，第一时间收到通知</text>
          </button>
        </view>
      </view>
    </view>
  </block>
</view>
