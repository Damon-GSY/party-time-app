/* 创建页面样式 - 精致动画版 */
.container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  padding: 32rpx;
  padding-bottom: 120rpx;
  box-sizing: border-box;
}

/* 表单分区 */
.form-section {
  margin-bottom: 48rpx;
  opacity: 0;
  transform: translateY(40rpx);
  animation: slideUpStagger 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}

/* nth-child 交错延迟 */
.form-section:nth-child(1) { animation-delay: 0s; }
.form-section:nth-child(2) { animation-delay: 0.07s; }
.form-section:nth-child(3) { animation-delay: 0.14s; }
.form-section:nth-child(4) { animation-delay: 0.21s; }
.form-section:nth-child(5) { animation-delay: 0.28s; }

/* showForm 驱动的入场（JS 设置后触发，更优雅） */
.form-section.visible {
  animation: none;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
              transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.form-section.visible:nth-child(1) { transition-delay: 0s; }
.form-section.visible:nth-child(2) { transition-delay: 0.07s; }
.form-section.visible:nth-child(3) { transition-delay: 0.14s; }
.form-section.visible:nth-child(4) { transition-delay: 0.21s; }
.form-section.visible:nth-child(5) { transition-delay: 0.28s; }

@keyframes slideUpStagger {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.label-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.label-required {
  color: var(--primary-color);
  margin-left: 8rpx;
  font-size: 28rpx;
}

.label-optional {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-left: 12rpx;
}

/* 输入框 */
.form-input {
  width: 100%;
  padding: 28rpx 32rpx;
  background: rgba(15, 52, 96, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #fff;
  box-sizing: border-box;
  transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
}

.form-input:focus,
.form-input.focused {
  border-color: var(--primary-color);
  background: rgba(15, 52, 96, 0.8);
  box-shadow: 0 0 0 4rpx rgba(233, 69, 96, 0.15), 0 0 20rpx rgba(233, 69, 96, 0.1);
}

.form-input::placeholder {
  color: var(--text-muted);
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 12rpx;
  text-align: right;
}

/* 日期选择器 */
.date-picker {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.picker-value {
  flex: 1;
  padding: 28rpx 24rpx;
  background: rgba(15, 52, 96, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #fff;
  text-align: center;
  transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease, transform 0.2s ease;
}

.picker-value:active {
  transform: scale(0.97);
  background: rgba(15, 52, 96, 0.8);
  border-color: var(--primary-color);
}

.picker-value.placeholder {
  color: var(--text-muted);
}

.date-separator {
  font-size: 26rpx;
  color: var(--text-secondary);
  padding: 0 8rpx;
}

/* 粒度选项 */
.granularity-options {
  display: flex;
  gap: 16rpx;
}

.granularity-option {
  flex: 1;
  padding: 28rpx 12rpx;
  background: rgba(15, 52, 96, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  text-align: center;
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
              border-color 0.3s ease,
              background 0.3s ease,
              box-shadow 0.3s ease;
}

.granularity-option:active {
  transform: scale(0.95);
}

.granularity-option.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: var(--primary-color);
  transform: scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(233, 69, 96, 0.25);
}

.option-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 8rpx;
  transition: color 0.3s ease;
}

.granularity-option.active .option-title {
  color: var(--primary-light);
}

.option-desc {
  font-size: 22rpx;
  color: var(--text-muted);
  transition: color 0.3s ease;
}

.granularity-option.active .option-desc {
  color: var(--text-secondary);
}

/* 过期时间选项 */
.expire-options {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.expire-option {
  padding: 20rpx 32rpx;
  background: rgba(15, 52, 96, 0.4);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1),
              border-color 0.3s ease,
              background 0.3s ease,
              color 0.3s ease,
              box-shadow 0.3s ease;
}

.expire-option:active {
  transform: scale(0.92);
}

.expire-option.active {
  background: rgba(233, 69, 96, 0.2);
  border-color: var(--primary-color);
  color: var(--primary-light);
  transform: scale(1.05);
  box-shadow: 0 6rpx 20rpx rgba(233, 69, 96, 0.2);
}

/* 文本域 */
.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 28rpx 32rpx;
  background: rgba(15, 52, 96, 0.6);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #fff;
  box-sizing: border-box;
  line-height: 1.6;
  transition: border-color 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
}

.form-textarea:focus,
.form-textarea.focused {
  border-color: var(--primary-color);
  background: rgba(15, 52, 96, 0.8);
  box-shadow: 0 0 0 4rpx rgba(233, 69, 96, 0.15), 0 0 20rpx rgba(233, 69, 96, 0.1);
}

.form-textarea::placeholder {
  color: var(--text-muted);
}

/* 提交按钮区域 */
.form-actions {
  margin-top: 64rpx;
  opacity: 0;
  transform: translateY(30rpx);
  animation: slideUpStagger 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) 0.35s forwards;
}

/* showForm 驱动的入场 */
.form-actions.visible {
  animation: none;
  opacity: 1;
  transform: translateY(0);
  transition: opacity 0.5s cubic-bezier(0.34, 1.56, 0.64, 1),
              transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
  transition-delay: 0.35s;
}

.submit-btn {
  width: 100%;
  height: 108rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
  border: none;
  box-shadow: 0 12rpx 40rpx rgba(233, 69, 96, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1),
              box-shadow 0.3s ease,
              background 0.4s ease,
              opacity 0.4s ease;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  animation: shimmer 2s ease-in-out infinite;
}

.submit-btn::after {
  display: none;
}

.submit-btn:active:not(.disabled) {
  transform: scale(0.94);
  box-shadow: 0 4rpx 12rpx rgba(233, 69, 96, 0.3);
}

.submit-btn.disabled {
  background: rgba(107, 107, 107, 0.3);
  box-shadow: none;
  opacity: 0.5;
}

.submit-btn.disabled::before {
  display: none;
}

@keyframes shimmer {
  0% { left: -100%; }
  50%, 100% { left: 100%; }
}

/* 加载动画 */
.submit-btn.loading {
  pointer-events: none;
}

.submit-btn.loading::before {
  display: none;
}

/* ===== Hero UI / Aceternity 升级 ===== */

/* Lamp Effect */
.lamp-container {
  position: fixed;
  top: -40rpx;
  left: 0; right: 0;
  height: 120rpx;
  pointer-events: none;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
}
.create-lamp-glow {
  width: 500rpx;
  height: 300rpx;
  background: radial-gradient(ellipse at center top, rgba(233, 69, 96, 0.15) 0%, transparent 70%);
  animation: lamp-form-breathe 5s ease-in-out infinite;
}
@keyframes lamp-form-breathe {
  0%, 100% { opacity: 0.5; transform: scale(1); }
  50% { opacity: 1; transform: scale(1.1); }
}
.lamp-beam {
  width: 3rpx;
  height: 80rpx;
  background: linear-gradient(to bottom, rgba(233, 69, 96, 0.6), transparent);
}

/* 微弱 Beams */
.form-beams {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  overflow: hidden;
  z-index: 0;
}
.form-beam {
  position: absolute;
  height: 1rpx;
  left: -10%;
  width: 120%;
}
.form-beam:nth-child(1) {
  top: 30%;
  background: linear-gradient(90deg, transparent, rgba(233, 69, 96, 0.08), transparent);
  animation: beam-sweep 10s ease-in-out infinite;
}
.form-beam:nth-child(2) {
  top: 70%;
  background: linear-gradient(90deg, transparent, rgba(255, 107, 107, 0.06), transparent);
  animation: beam-sweep 12s ease-in-out infinite 3s;
}

/* Glass Form Section */
.glass-form-section {
  background: var(--glass-bg);
  backdrop-filter: blur(var(--glass-blur));
  -webkit-backdrop-filter: blur(var(--glass-blur));
  border: 2rpx solid var(--glass-border);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  position: relative;
  overflow: hidden;
}
.glass-form-section::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, rgba(233, 69, 96, 0.3), transparent);
}

/* Spotlight 选项卡片 */
.granularity-option.spotlight-card {
  position: relative;
  overflow: hidden;
  background: rgba(15, 52, 96, 0.35);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}
.granularity-option .spotlight-overlay { z-index: 1; }
.option-content { position: relative; z-index: 2; }

/* 过期选项 spotlight */
.expire-option.spotlight-card {
  position: relative;
  overflow: hidden;
  background: rgba(15, 52, 96, 0.35);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

/* Border Beam 提交按钮 */
.submit-beam { width: 100%; }
.submit-beam::after { background: linear-gradient(160deg, #1a1a2e, #16213e); }
.submit-beam .beam-content { width: 100%; }

.glass-submit {
  background: rgba(233, 69, 96, 0.15);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
}
.glass-submit.disabled {
  background: rgba(107, 107, 107, 0.3);
  backdrop-filter: none;
}
