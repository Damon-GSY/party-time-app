<!--创建聚会页面-->
<view class="container">
  <form bindsubmit="handleSubmit">
    <!-- 聚会名称 -->
    <view class="form-section">
      <view class="form-label">
        <text class="label-text">聚会名称</text>
        <text class="label-required">*</text>
      </view>
      <input
        class="form-input"
        name="name"
        placeholder="例如：周末聚餐、生日派对、团建活动..."
        value="{{name}}"
        bindinput="onNameInput"
        maxlength="30"
      />
      <view class="form-hint">{{name.length || 0}}/30</view>
    </view>

    <!-- 日期范围 -->
    <view class="form-section">
      <view class="form-label">
        <text class="label-text">日期范围</text>
        <text class="label-required">*</text>
      </view>
      <view class="date-picker">
        <picker
          mode="date"
          value="{{startDate}}"
          start="{{today}}"
          bindchange="onStartDateChange"
        >
          <view class="picker-value {{startDate ? '' : 'placeholder'}}">
            {{startDate || '开始日期'}}
          </view>
        </picker>
        <view class="date-separator">至</view>
        <picker
          mode="date"
          value="{{endDate}}"
          start="{{startDate || today}}"
          bindchange="onEndDateChange"
        >
          <view class="picker-value {{endDate ? '' : 'placeholder'}}">
            {{endDate || '结束日期'}}
          </view>
        </picker>
      </view>
      <view class="form-hint" wx:if="{{dateCount > 0}}">
        共 {{dateCount}} 天
      </view>
    </view>

    <!-- 时段粒度 -->
    <view class="form-section">
      <view class="form-label">
        <text class="label-text">时段粒度</text>
      </view>
      <view class="granularity-options">
        <view
          class="granularity-option {{granularity === 'hour' ? 'active' : ''}}"
          bindtap="selectGranularity"
          data-value="hour"
        >
          <view class="option-title">1小时</view>
          <view class="option-desc">精确安排</view>
        </view>
        <view
          class="granularity-option {{granularity === 'twoHours' ? 'active' : ''}}"
          bindtap="selectGranularity"
          data-value="twoHours"
        >
          <view class="option-title">2小时</view>
          <view class="option-desc">推荐</view>
        </view>
        <view
          class="granularity-option {{granularity === 'halfDay' ? 'active' : ''}}"
          bindtap="selectGranularity"
          data-value="halfDay"
        >
          <view class="option-title">半天</view>
          <view class="option-desc">快速选择</view>
        </view>
      </view>
    </view>

    <!-- 过期时间 -->
    <view class="form-section">
      <view class="form-label">
        <text class="label-text">过期时间</text>
      </view>
      <view class="expire-options">
        <view
          class="expire-option {{expireType === '24h' ? 'active' : ''}}"
          bindtap="selectExpire"
          data-value="24h"
        >
          24小时
        </view>
        <view
          class="expire-option {{expireType === '3days' ? 'active' : ''}}"
          bindtap="selectExpire"
          data-value="3days"
        >
          3天
        </view>
        <view
          class="expire-option {{expireType === '7days' ? 'active' : ''}}"
          bindtap="selectExpire"
          data-value="7days"
        >
          7天
        </view>
        <view
          class="expire-option {{expireType === 'never' ? 'active' : ''}}"
          bindtap="selectExpire"
          data-value="never"
        >
          永久
        </view>
      </view>
    </view>

    <!-- 备注 -->
    <view class="form-section">
      <view class="form-label">
        <text class="label-text">备注说明</text>
        <text class="label-optional">（可选）</text>
      </view>
      <textarea
        class="form-textarea"
        name="note"
        placeholder="添加一些说明，比如活动地点、注意事项等..."
        value="{{note}}"
        bindinput="onNoteInput"
        maxlength="200"
      />
      <view class="form-hint">{{note.length || 0}}/200</view>
    </view>

    <!-- 提交按钮 -->
    <view class="form-actions">
      <button
        class="submit-btn {{canSubmit ? '' : 'disabled'}}"
        form-type="submit"
        disabled="{{!canSubmit || submitting}}"
      >
        {{submitting ? '创建中...' : '创建聚会'}}
      </button>
    </view>
  </form>
</view>
