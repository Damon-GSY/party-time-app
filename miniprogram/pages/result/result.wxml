<!--统计结果页面 - 偏好加权版-->
<view class="page-container">
  <!-- 加载状态 -->
  <view class="loading-screen" wx:if="{{loading}}">
    <view class="loading-animation">
      <view class="loading-ring"></view>
      <view class="loading-ring"></view>
    </view>
    <text class="loading-text">加载统计数据...</text>
  </view>

  <!-- 主内容 -->
  <block wx:else>
    <!-- 头部信息 -->
    <view class="header-section fade-in">
      <view class="event-header">
        <text class="event-name">{{event.name}}</text>
        <view class="event-badges">
          <view class="badge {{event.expired ? 'expired' : ''}}">
            {{event.expired ? '已过期' : event.expireText}}
          </view>
        </view>
      </view>
      <view class="event-meta">
        <text class="meta-item">{{event.dateRangeText}}</text>
      </view>
      <text class="event-note" wx:if="{{event.note}}">{{event.note}}</text>
    </view>

    <!-- 统计卡片：参与人数 + 最高票数 + 共识度 -->
    <view class="stats-cards fade-in" style="animation-delay: 0.1s;">
      <view class="stat-card-wrapper shimmer-border">
        <view class="stat-card glass-stat-card">
          <view class="stat-value">
            <text class="stat-number">{{displayParticipantCount}}</text>
          </view>
          <text class="stat-label">参与人数</text>
        </view>
      </view>
      <view class="stat-card-wrapper shimmer-border">
        <view class="stat-card glass-stat-card">
          <view class="stat-value">
            <text class="stat-number">{{displayBestCount}}</text>
          </view>
          <text class="stat-label">最高票数</text>
        </view>
      </view>
      <view class="stat-card-wrapper shimmer-border">
        <view class="stat-card glass-stat-card">
          <view class="stat-value">
            <text class="stat-number consensus-num" style="color: {{consensusColor}};">{{displayConsensus}}%</text>
          </view>
          <text class="stat-label" style="color: {{consensusColor}};">{{consensusLabel}}</text>
        </view>
      </view>
    </view>

    <!-- Top 3 推荐时段 -->
    <view class="recommend-section fade-in" style="animation-delay: 0.15s;">
      <view class="section-header">
        <text class="section-title">推荐时段</text>
      </view>

      <block wx:if="{{topRecommendations.length > 0}}">
        <view class="top3-list">
          <view
            class="top3-card {{item.rank === 1 ? 'top3-rank1' : ''}} slide-in-bounce"
            wx:for="{{topRecommendations}}"
            wx:key="slotId"
            style="animation-delay: {{0.1 * index}}s;"
          >
            <!-- 排名 + 帕累托标签 -->
            <view class="top3-header">
              <view class="top3-rank-badge rank-{{item.rank}}">{{item.rank}}</view>
              <view class="top3-pareto-badge" wx:if="{{item.isPareto}}">帕累托最优</view>
            </view>
            <!-- 时间 -->
            <text class="top3-time">{{item.timeLabel}}</text>
            <!-- 偏好得分 -->
            <view class="top3-score-row">
              <text class="top3-score-label">偏好得分</text>
              <text class="top3-score-value">{{item.satisfactionPercent}}%</text>
            </view>
            <!-- 满意度分布条 -->
            <view class="top3-bar-wrap">
              <view class="top3-bar">
                <view class="top3-bar-green" style="width: {{item.hardCount / participantCount * 100}}%;"></view>
                <view class="top3-bar-yellow" style="width: {{item.reluctantCount / participantCount * 100}}%;"></view>
              </view>
              <view class="top3-bar-labels">
                <text class="bar-label green">{{item.hardCount}}人方便</text>
                <text class="bar-label yellow" wx:if="{{item.reluctantCount > 0}}">{{item.reluctantCount}}人勉强</text>
              </view>
            </view>
          </view>
        </view>
      </block>

      <!-- 空状态 -->
      <view class="recommend-card recommend-empty" wx:else>
        <view class="recommend-icon-wrap">
          <text class="recommend-empty-icon">🗳️</text>
        </view>
        <view class="recommend-content">
          <text class="recommend-label">暂无数据</text>
          <text class="recommend-time">等待参与者投票</text>
          <text class="recommend-hint">分享给好友开始投票吧~</text>
        </view>
      </view>
    </view>

    <!-- 偏好加权热力图 -->
    <view class="heatmap-section fade-in" style="animation-delay: 0.2s;" wx:if="{{participantCount > 0}}">
      <view class="section-header">
        <text class="section-title">偏好热力图</text>
      </view>

      <!-- 图例 -->
      <view class="legend-bar">
        <text class="legend-label">偏好得分：</text>
        <view class="legend-gradient">
          <view class="legend-step" wx:for="{{legendSteps}}" wx:key="value" style="background: {{item.color}};">
            <text class="legend-value">{{item.value}}</text>
          </view>
        </view>
        <text class="legend-hint">点击查看详情</text>
      </view>

      <!-- 日期标签 -->
      <view class="date-labels">
        <view class="date-label" wx:for="{{dates}}" wx:key="date">
          <text class="label-weekday">{{item.weekday}}</text>
          <text class="label-day">{{item.day}}日</text>
        </view>
      </view>

      <!-- 时间轴 + 热力格子 -->
      <view class="heatmap-wrapper">
        <view class="time-column">
          <text class="time-text" wx:for="{{timeLabels}}" wx:key="*this">{{item}}</text>
        </view>

        <view class="heatmap-grid">
          <view class="heatmap-column" wx:for="{{dates}}" wx:key="date">
            <view
              class="heatmap-cell hlevel-{{item.level}} glass-heatmap-cell {{item.isPareto ? 'pareto-cell' : ''}}"
              wx:for="{{item.slots}}"
              wx:key="slotId"
              bindtap="showSlotDetail"
              data-slot-id="{{item.slotId}}"
              hover-class="heatmap-cell-hover"
            >
              <text class="cell-pareto-star" wx:if="{{item.isPareto}}">★</text>
              <text class="cell-pref" wx:if="{{item.prefScore > 0}}">{{item.prefScore}}%</text>
              <text class="cell-detail" wx:if="{{item.count > 0}}">{{item.hardCount}}✓ {{item.reluctantCount}}~</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态引导 -->
    <view class="empty-participants fade-in" style="animation-delay: 0.2s;" wx:if="{{participantCount === 0}}">
      <view class="empty-icon breathe-float">
        <text>👥</text>
      </view>
      <text class="empty-title">还没有人参与</text>
      <text class="empty-desc">分享给好友，让大家一起选时间吧！</text>
      <button class="empty-share-btn shimmer-btn" open-type="share">
        <text>立即分享</text>
      </button>
    </view>

    <!-- 参与者列表 -->
    <view class="participants-section fade-in" style="animation-delay: 0.25s;" wx:if="{{participants.length > 0}}">
      <view class="section-header">
        <text class="section-title">参与者 ({{participants.length}}人)</text>
      </view>
      <view class="participants-list">
        <view
          class="participant-card slide-in-bounce"
          wx:for="{{participants}}"
          wx:key="_id"
          style="animation-delay: {{0.05 * index}}s;"
        >
          <view class="participant-avatar avatar-bounce" style="background: {{item.avatarColor || 'linear-gradient(135deg, var(--primary-color), var(--primary-light))'}}">
            <text>{{item.nickname[0]}}</text>
          </view>
          <view class="participant-info">
            <text class="participant-name">{{item.nickname}}</text>
            <text class="participant-slots">选择了 {{item.slotCount}} 个时段</text>
          </view>
          <view class="participant-badge badge-sparkle" wx:if="{{item.slotCount >= 5}}">
            <text>🌟</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-section fade-in" style="animation-delay: 0.3s;">
      <button
        class="notify-btn {{notifying ? 'notifying' : ''}}"
        bindtap="notifyParticipants"
        wx:if="{{isCreator && participantCount > 1 && bestSlot.timeText}}"
        disabled="{{notifying}}"
      >
        <text class="btn-icon">🔔</text>
        <text>{{notifying ? '发送中...' : '通知参与者'}}</text>
      </button>
      <button class="share-btn" open-type="share">
        <text class="btn-icon">🔗</text>
        <text>分享结果</text>
      </button>
      <button class="poster-btn" bindtap="goToPoster">
        <text class="btn-icon">🖼️</text>
        <text>生成海报</text>
      </button>
      <button class="vote-btn" bindtap="goToVote" wx:if="{{!event.expired}}">
        <text class="btn-icon">✏️</text>
        <text>填写/修改</text>
      </button>
    </view>

    <!-- 刚创建成功的提示 -->
    <view class="created-tip fade-in" style="animation-delay: 0.35s;" wx:if="{{justCreated}}">
      <view class="tip-content">
        <text class="tip-icon">🎉</text>
        <text class="tip-text">聚会创建成功！快分享给好友吧</text>
      </view>
    </view>

    <!-- 时段详情弹窗（偏好版） -->
    <view class="slot-modal {{showSlotModal ? 'show' : ''}}" catchtouchmove="preventMove">
      <view class="modal-backdrop" bindtap="closeSlotModal"></view>
      <view class="modal-content glass-modal">
        <view class="modal-header">
          <text class="modal-title">{{selectedSlotInfo.dateText}} {{selectedSlotInfo.timeText}}</text>
          <view class="modal-header-right">
            <text class="modal-count">偏好得分 {{selectedSlotInfo.prefScore}}%</text>
            <view class="modal-close" bindtap="closeSlotModal" aria-label="关闭">×</view>
          </view>
        </view>
        <view class="modal-body">
          <!-- 有空 -->
          <view class="modal-group" wx:if="{{selectedSlotInfo.hardUsers.length > 0}}">
            <view class="modal-group-header">
              <text class="modal-group-dot green"></text>
              <text class="modal-group-label">有空（{{selectedSlotInfo.hardUsers.length}}人）</text>
            </view>
            <view class="participant-list">
              <view class="participant-item" wx:for="{{selectedSlotInfo.hardUsers}}" wx:key="*this">
                <view class="participant-avatar small">
                  <text>{{item[0]}}</text>
                </view>
                <text class="participant-name">{{item}}</text>
              </view>
            </view>
          </view>
          <!-- 勉强 -->
          <view class="modal-group" wx:if="{{selectedSlotInfo.reluctantUsers.length > 0}}">
            <view class="modal-group-header">
              <text class="modal-group-dot yellow"></text>
              <text class="modal-group-label">勉强（{{selectedSlotInfo.reluctantUsers.length}}人）</text>
            </view>
            <view class="participant-list">
              <view class="participant-item" wx:for="{{selectedSlotInfo.reluctantUsers}}" wx:key="*this">
                <view class="participant-avatar small">
                  <text>{{item[0]}}</text>
                </view>
                <text class="participant-name">{{item}}</text>
              </view>
            </view>
          </view>
          <!-- 不方便 -->
          <view class="modal-group" wx:if="{{selectedSlotInfo.unavailableUsers.length > 0}}">
            <view class="modal-group-header">
              <text class="modal-group-dot gray"></text>
              <text class="modal-group-label">不方便（{{selectedSlotInfo.unavailableUsers.length}}人）</text>
            </view>
            <view class="participant-list">
              <view class="participant-item" wx:for="{{selectedSlotInfo.unavailableUsers}}" wx:key="*this">
                <view class="participant-avatar small gray-avatar">
                  <text>{{item[0]}}</text>
                </view>
                <text class="participant-name unavailable-name">{{item}}</text>
              </view>
            </view>
          </view>
          <!-- 无数据 -->
          <view class="no-data" wx:if="{{selectedSlotInfo.hardUsers.length === 0 && selectedSlotInfo.reluctantUsers.length === 0}}">
            <text>暂无人选择此时段</text>
          </view>
        </view>
      </view>
    </view>
  </block>
</view>
