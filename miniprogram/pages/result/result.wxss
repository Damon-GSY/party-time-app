/* 统计结果页面样式 - 偏好加权版 */

.page-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  padding-bottom: 180rpx;
}

/* ========== 基础入场动画 ========== */

.fade-in {
  animation: fadeInUp 0.5s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.slide-in {
  animation: slideIn 0.4s ease forwards;
  opacity: 0;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

.slide-in-bounce {
  animation: slideInBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  opacity: 0;
}

@keyframes slideInBounce {
  from { opacity: 0; transform: translateX(-30rpx) scale(0.95); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

.avatar-bounce {
  animation: avatarPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  transform: scale(0);
}

@keyframes avatarPop {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

.badge-sparkle {
  animation: sparkleRotate 2s ease-in-out infinite;
}

@keyframes sparkleRotate {
  0%, 100% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(-15deg) scale(1.2); }
  50% { transform: rotate(0deg) scale(1); }
  75% { transform: rotate(15deg) scale(1.2); }
}

.breathe-float {
  animation: breatheFloat 3s ease-in-out infinite;
}

@keyframes breatheFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.7; }
  50% { transform: translateY(-16rpx) scale(1.05); opacity: 1; }
}

.shimmer-btn {
  position: relative;
  overflow: hidden;
}

.shimmer-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
  animation: shimmer 2.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* ========== 加载状态 ========== */

.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-animation {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.loading-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-ring:nth-child(2) {
  width: 70%;
  height: 70%;
  top: 15%;
  left: 15%;
  border-top-color: var(--primary-light);
  animation-duration: 0.7s;
  animation-direction: reverse;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ========== 头部信息 ========== */

.header-section { padding: 32rpx; }

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.event-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.event-badges { display: flex; gap: 12rpx; }

.badge {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(74, 222, 128, 0.15);
  color: #4ade80;
}

.badge.expired {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.event-meta { margin-bottom: 12rpx; }

.meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.event-note {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  margin-top: 12rpx;
}

/* ========== 统计卡片（3列） ========== */

.stats-cards {
  display: flex;
  gap: 16rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 24rpx 16rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.stat-value { margin-bottom: 6rpx; }

.stat-number {
  font-size: 48rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.consensus-num {
  -webkit-text-fill-color: initial;
  background: none;
  -webkit-background-clip: initial;
  background-clip: initial;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

/* ========== Top 3 推荐卡片 ========== */

.recommend-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.top3-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.top3-card {
  padding: 24rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 20rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.06);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  transition: all 0.3s ease;
}

.top3-card:active {
  transform: scale(0.98);
  background: rgba(15, 52, 96, 0.6);
}

.top3-card.top3-rank1 {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.12), rgba(251, 191, 36, 0.04));
  border-color: rgba(251, 191, 36, 0.3);
  box-shadow: 0 4rpx 24rpx rgba(251, 191, 36, 0.1);
}

.top3-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.top3-rank-badge {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
  background: rgba(255, 255, 255, 0.15);
}

.top3-rank-badge.rank-1 {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  box-shadow: 0 2rpx 12rpx rgba(251, 191, 36, 0.4);
}

.top3-rank-badge.rank-2 {
  background: rgba(192, 192, 192, 0.4);
}

.top3-rank-badge.rank-3 {
  background: rgba(205, 127, 50, 0.4);
}

.top3-pareto-badge {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
  color: #fbbf24;
  background: rgba(251, 191, 36, 0.12);
  border: 1rpx solid rgba(251, 191, 36, 0.3);
  font-weight: 500;
}

.top3-time {
  font-size: 30rpx;
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: 12rpx;
}

.top3-score-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.top3-score-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.top3-score-value {
  font-size: 30rpx;
  font-weight: 700;
  color: #4ade80;
}

/* 满意度分布条 */
.top3-bar-wrap {
  margin-top: 4rpx;
}

.top3-bar {
  display: flex;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.06);
}

.top3-bar-green {
  background: #4ade80;
  transition: width 0.5s ease;
}

.top3-bar-yellow {
  background: #fbbf24;
  transition: width 0.5s ease;
}

.top3-bar-labels {
  display: flex;
  gap: 16rpx;
  margin-top: 6rpx;
}

.bar-label {
  font-size: 20rpx;
}

.bar-label.green { color: #4ade80; }
.bar-label.yellow { color: #fbbf24; }

/* ========== 空推荐 ========== */

.recommend-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.recommend-card.recommend-empty {
  background: linear-gradient(135deg, rgba(107, 107, 128, 0.15), rgba(107, 107, 128, 0.05));
  border: 2rpx solid rgba(107, 107, 128, 0.2);
}

.recommend-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recommend-empty-icon {
  font-size: 48rpx;
  animation: float-emoji 3s ease-in-out infinite;
}

@keyframes float-emoji {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.recommend-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recommend-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.recommend-time {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.recommend-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ========== 偏好加权热力图 ========== */

.heatmap-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.legend-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
  padding: 14rpx 18rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.legend-label {
  font-size: 22rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.legend-gradient {
  display: flex;
  flex: 1;
  gap: 4rpx;
}

.legend-step {
  flex: 1;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 6rpx;
}

.legend-value {
  font-size: 18rpx;
  font-weight: 600;
  color: #fff;
}

.legend-hint {
  font-size: 18rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.date-labels {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 64rpx;
}

.date-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 12rpx;
}

.label-weekday {
  font-size: 20rpx;
  color: var(--text-muted);
}

.label-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.heatmap-wrapper {
  display: flex;
  gap: 12rpx;
}

.time-column {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-text {
  height: 80rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.heatmap-grid {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.heatmap-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  animation: columnFadeIn 0.4s ease forwards;
  opacity: 0;
}

.heatmap-column:nth-child(1) { animation-delay: 0.1s; }
.heatmap-column:nth-child(2) { animation-delay: 0.2s; }
.heatmap-column:nth-child(3) { animation-delay: 0.3s; }
.heatmap-column:nth-child(4) { animation-delay: 0.4s; }
.heatmap-column:nth-child(5) { animation-delay: 0.5s; }
.heatmap-column:nth-child(6) { animation-delay: 0.6s; }
.heatmap-column:nth-child(7) { animation-delay: 0.7s; }

@keyframes columnFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* 热力格子 - 5级偏好渐变 */
.heatmap-cell {
  height: 80rpx;
  min-height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: background-color 0.5s ease, transform 0.3s ease, box-shadow 0.3s ease;
  cursor: pointer;
  position: relative;
  animation: cellFadeIn 0.3s ease forwards;
  opacity: 0;
  overflow: hidden;
}

.heatmap-cell:nth-child(1) { animation-delay: 0.05s; }
.heatmap-cell:nth-child(2) { animation-delay: 0.1s; }
.heatmap-cell:nth-child(3) { animation-delay: 0.15s; }
.heatmap-cell:nth-child(4) { animation-delay: 0.2s; }
.heatmap-cell:nth-child(5) { animation-delay: 0.25s; }
.heatmap-cell:nth-child(6) { animation-delay: 0.3s; }
.heatmap-cell:nth-child(7) { animation-delay: 0.35s; }
.heatmap-cell:nth-child(8) { animation-delay: 0.4s; }
.heatmap-cell:nth-child(9) { animation-delay: 0.45s; }
.heatmap-cell:nth-child(10) { animation-delay: 0.5s; }
.heatmap-cell:nth-child(11) { animation-delay: 0.55s; }
.heatmap-cell:nth-child(12) { animation-delay: 0.6s; }

@keyframes cellFadeIn {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}

.heatmap-cell-hover {
  transform: scale(1.08);
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

/* 5级偏好渐变色 */
.heatmap-cell.hlevel-0 { background: #1a1a2e; }
.heatmap-cell.hlevel-1 { background: #1e3a5f; }
.heatmap-cell.hlevel-2 { background: #2d6a4f; }
.heatmap-cell.hlevel-3 { background: rgba(251, 191, 36, 0.45); }
.heatmap-cell.hlevel-4 {
  background: linear-gradient(135deg, #e94560, #ff6b6b);
  box-shadow: 0 2rpx 12rpx rgba(233, 69, 96, 0.3);
}

/* 帕累托最优格子 */
.pareto-cell {
  box-shadow: 0 0 0 2rpx rgba(251, 191, 36, 0.5);
}

.cell-pareto-star {
  position: absolute;
  top: 2rpx;
  left: 6rpx;
  font-size: 16rpx;
  color: #fbbf24;
  line-height: 1;
}

.cell-pref {
  font-size: 22rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.cell-detail {
  font-size: 16rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.2;
}

/* ========== 空状态引导 ========== */

.empty-participants {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
  text-align: center;
}

.empty-share-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

.empty-share-btn::after { display: none; }

/* ========== 参与者列表 ========== */

.participants-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.participants-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.participant-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.participant-card:active {
  background: rgba(15, 52, 96, 0.6);
  transform: scale(0.98);
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
  position: relative;
}

.participant-avatar::after {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 50%;
  background: conic-gradient(from 0deg, var(--primary-color), var(--primary-light), #fbbf24, var(--primary-color));
  z-index: -1;
  animation: avatar-ring-rotate 4s linear infinite;
  opacity: 0.6;
}

@keyframes avatar-ring-rotate { to { transform: rotate(360deg); } }

.participant-avatar.small {
  width: 48rpx;
  height: 48rpx;
  font-size: 22rpx;
}

.participant-avatar.small::after { display: none; }

.gray-avatar {
  background: rgba(107, 107, 128, 0.3) !important;
}

.unavailable-name {
  color: var(--text-muted) !important;
}

.participant-info { flex: 1; }

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 4rpx;
}

.participant-slots {
  font-size: 24rpx;
  color: var(--text-muted);
}

.participant-badge { font-size: 24rpx; }

/* ========== 操作按钮 ========== */

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(26, 26, 46, 0.98), transparent);
  display: flex;
  gap: 20rpx;
}

.share-btn,
.vote-btn,
.notify-btn,
.poster-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.share-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.share-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
}

.vote-btn {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
}

.vote-btn:active {
  transform: scale(0.98);
}

.notify-btn {
  width: 100%;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #fff;
}

.notify-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.notify-btn.notifying {
  opacity: 0.7;
}

.poster-btn {
  background: rgba(251, 191, 36, 0.15);
  color: #fbbf24;
  border: 2rpx solid rgba(251, 191, 36, 0.25);
}

.poster-btn:active {
  background: rgba(251, 191, 36, 0.25);
  transform: scale(0.98);
}

.poster-btn::after {
  display: none;
}

.btn-icon { font-size: 28rpx; }

/* ========== 创建成功提示 ========== */

.created-tip {
  position: fixed;
  top: 32rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
}

.tip-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: rgba(74, 222, 128, 0.15);
  border: 2rpx solid rgba(74, 222, 128, 0.3);
  border-radius: 16rpx;
}

.tip-icon { font-size: 32rpx; }

.tip-text {
  font-size: 26rpx;
  color: #4ade80;
}

/* ========== 偏好详情弹窗 ========== */

.slot-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.slot-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 70vh;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%) scale(0.9);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
}

.slot-modal.show .modal-content {
  transform: translateY(0) scale(1);
  opacity: 1;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  flex: 1;
}

.modal-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-count {
  font-size: 24rpx;
  color: #4ade80;
  background: rgba(74, 222, 128, 0.12);
  padding: 6rpx 14rpx;
  border-radius: 10rpx;
}

.modal-close {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.modal-body {
  max-height: 50vh;
  overflow-y: auto;
}

/* 弹窗分组 */
.modal-group {
  margin-bottom: 24rpx;
}

.modal-group-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.modal-group-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.modal-group-dot.green { background: #4ade80; }
.modal-group-dot.yellow { background: #fbbf24; }
.modal-group-dot.gray { background: rgba(107, 107, 128, 0.5); }

.modal-group-label {
  font-size: 26rpx;
  color: var(--text-secondary);
  font-weight: 500;
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.no-data {
  text-align: center;
  padding: 48rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}

/* ========== Glass 效果 ========== */

.stat-card-wrapper {
  flex: 1;
  border-radius: 24rpx;
  overflow: hidden;
}

.stat-card-wrapper::after {
  background: rgba(15, 52, 96, 0.8);
  border-radius: 22rpx;
}

.stat-card-wrapper .stat-card { position: relative; z-index: 1; border-radius: 22rpx; }

.glass-stat-card {
  background: rgba(15, 52, 96, 0.4);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.06);
}

.glass-heatmap-cell {
  position: relative;
  overflow: hidden;
}

.glass-modal {
  background: rgba(15, 52, 96, 0.7);
  backdrop-filter: blur(40rpx);
  -webkit-backdrop-filter: blur(40rpx);
  border: 2rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 -8rpx 40rpx rgba(0, 0, 0, 0.3);
}
