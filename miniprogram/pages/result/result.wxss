/* \u7edf\u8ba1\u7ed3\u679c\u9875\u9762\u6837\u5f0f - \u52a8\u753b\u589e\u5f3a\u7248 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  padding-bottom: 180rpx;
}

/* ========== \u57fa\u7840\u5165\u573a\u52a8\u753b ========== */

.fade-in {
  animation: fadeInUp 0.5s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* \u6ed1\u5165\u52a8\u753b\uff08\u4fdd\u7559\u517c\u5bb9\uff09 */
.slide-in {
  animation: slideIn 0.4s ease forwards;
  opacity: 0;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(-20rpx); }
  to { opacity: 1; transform: translateX(0); }
}

/* \u589e\u5f3a\u5f39\u6027\u6ed1\u5165 */
.slide-in-bounce {
  animation: slideInBounce 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  opacity: 0;
}

@keyframes slideInBounce {
  from { opacity: 0; transform: translateX(-30rpx) scale(0.95); }
  to { opacity: 1; transform: translateX(0) scale(1); }
}

/* \u5934\u50cf\u5f39\u6027\u51fa\u73b0 */
.avatar-bounce {
  animation: avatarPop 0.5s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
  transform: scale(0);
}

@keyframes avatarPop {
  0% { transform: scale(0); opacity: 0; }
  60% { transform: scale(1.15); }
  100% { transform: scale(1); opacity: 1; }
}

/* \u661f\u661f\u5fbd\u7ae0\u95ea\u70c1\u65cb\u8f6c */
.badge-sparkle {
  animation: sparkleRotate 2s ease-in-out infinite;
}

@keyframes sparkleRotate {
  0%, 100% { transform: rotate(0deg) scale(1); }
  25% { transform: rotate(-15deg) scale(1.2); }
  50% { transform: rotate(0deg) scale(1); }
  75% { transform: rotate(15deg) scale(1.2); }
}

/* \u7a7a\u72b6\u6001\u4eba\u7269\u547c\u5438\u6d6e\u52a8 */
.breathe-float {
  animation: breatheFloat 3s ease-in-out infinite;
}

@keyframes breatheFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.7; }
  50% { transform: translateY(-16rpx) scale(1.05); opacity: 1; }
}

/* Shimmer \u5149\u6548\u6309\u94ae */
.shimmer-btn {
  position: relative;
  overflow: hidden;
}

.shimmer-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.2) 50%, transparent 100%);
  animation: shimmer 2.5s ease-in-out infinite;
}

@keyframes shimmer {
  0% { left: -100%; }
  100% { left: 100%; }
}

/* ========== \u52a0\u8f7d\u72b6\u6001 ========== */

.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-animation {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.loading-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-ring:nth-child(2) {
  width: 70%;
  height: 70%;
  top: 15%;
  left: 15%;
  border-top-color: var(--primary-light);
  animation-duration: 0.7s;
  animation-direction: reverse;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* ========== \u5934\u90e8\u4fe1\u606f ========== */

.header-section { padding: 32rpx; }

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.event-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.event-badges { display: flex; gap: 12rpx; }

.badge {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(74, 222, 128, 0.15);
  color: #4ade80;
}

.badge.expired {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.event-meta { margin-bottom: 12rpx; }

.meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.event-note {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  margin-top: 12rpx;
}

/* ========== \u7edf\u8ba1\u5361\u7247 ========== */

.stats-cards {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 28rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.stat-value { margin-bottom: 8rpx; }

.stat-number {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* ========== \u63a8\u8350\u5361\u7247 - Spring Bounce + \u547c\u5438\u5149\u6548 ========== */

.recommend-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.recommend-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.recommend-card.recommend-highlight {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(251, 191, 36, 0.08));
  border: 2rpx solid rgba(251, 191, 36, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(251, 191, 36, 0.15);
  animation: recommendBounce 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards,
             recommendGlow 3s ease-in-out 0.6s infinite;
  opacity: 0;
  transform: translateY(-30rpx) scale(0.95);
}

@keyframes recommendBounce {
  from { opacity: 0; transform: translateY(-30rpx) scale(0.95); }
  to { opacity: 1; transform: translateY(0) scale(1); }
}

@keyframes recommendGlow {
  0%, 100% { box-shadow: 0 8rpx 32rpx rgba(251, 191, 36, 0.15); }
  50% { box-shadow: 0 8rpx 40rpx rgba(251, 191, 36, 0.35), 0 0 60rpx rgba(251, 191, 36, 0.1); }
}

.recommend-card.recommend-empty {
  background: linear-gradient(135deg, rgba(107, 107, 128, 0.15), rgba(107, 107, 128, 0.05));
  border: 2rpx solid rgba(107, 107, 128, 0.2);
}

.recommend-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recommend-trophy {
  font-size: 56rpx;
  animation: trophyFloat 2.5s cubic-bezier(0.34, 1.56, 0.64, 1) infinite;
  filter: drop-shadow(0 4rpx 8rpx rgba(251, 191, 36, 0.3));
}

@keyframes trophyFloat {
  0%, 100% { transform: translateY(0) rotate(-5deg) scale(1); }
  25% { transform: translateY(-12rpx) rotate(3deg) scale(1.05); }
  50% { transform: translateY(-6rpx) rotate(5deg) scale(1.1); }
  75% { transform: translateY(-10rpx) rotate(-3deg) scale(1.05); }
}

.recommend-empty-icon {
  font-size: 48rpx;
  animation: float-emoji 3s ease-in-out infinite;
}

@keyframes float-emoji {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.recommend-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recommend-label {
  font-size: 22rpx;
  color: #fbbf24;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.recommend-card.recommend-empty .recommend-label {
  color: var(--text-secondary);
}

.recommend-time {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.recommend-meta {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.recommend-count {
  font-size: 26rpx;
  color: #fbbf24;
  font-weight: 600;
}

.recommend-percent {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.recommend-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* ========== \u70ed\u529b\u56fe ========== */

.heatmap-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

.legend-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.legend-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.legend-gradient {
  display: flex;
  flex: 1;
  gap: 4rpx;
}

.legend-step {
  flex: 1;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}

.legend-value {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

.legend-hint {
  font-size: 20rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

.date-labels {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 64rpx;
}

.date-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 12rpx;
}

.label-weekday {
  font-size: 20rpx;
  color: var(--text-muted);
}

.label-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

.heatmap-wrapper {
  display: flex;
  gap: 12rpx;
}

.time-column {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-text {
  height: 80rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.heatmap-grid {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

/* \u70ed\u529b\u5217 - \u4ea4\u9519\u5165\u573a */
.heatmap-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  animation: columnFadeIn 0.4s ease forwards;
  opacity: 0;
}

.heatmap-column:nth-child(1) { animation-delay: 0.1s; }
.heatmap-column:nth-child(2) { animation-delay: 0.2s; }
.heatmap-column:nth-child(3) { animation-delay: 0.3s; }
.heatmap-column:nth-child(4) { animation-delay: 0.4s; }
.heatmap-column:nth-child(5) { animation-delay: 0.5s; }
.heatmap-column:nth-child(6) { animation-delay: 0.6s; }
.heatmap-column:nth-child(7) { animation-delay: 0.7s; }

@keyframes columnFadeIn {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

/* \u70ed\u529b\u683c\u5b50 - \u6e10\u5165 + \u989c\u8272\u8fc7\u6e21 */
.heatmap-cell {
  height: 80rpx;
  min-height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background-color 0.5s ease, transform 0.3s ease, box-shadow 0.3s ease;
  cursor: pointer;
  position: relative;
  animation: cellFadeIn 0.3s ease forwards;
  opacity: 0;
}

.heatmap-cell:nth-child(1) { animation-delay: 0.05s; }
.heatmap-cell:nth-child(2) { animation-delay: 0.1s; }
.heatmap-cell:nth-child(3) { animation-delay: 0.15s; }
.heatmap-cell:nth-child(4) { animation-delay: 0.2s; }
.heatmap-cell:nth-child(5) { animation-delay: 0.25s; }
.heatmap-cell:nth-child(6) { animation-delay: 0.3s; }
.heatmap-cell:nth-child(7) { animation-delay: 0.35s; }
.heatmap-cell:nth-child(8) { animation-delay: 0.4s; }
.heatmap-cell:nth-child(9) { animation-delay: 0.45s; }
.heatmap-cell:nth-child(10) { animation-delay: 0.5s; }
.heatmap-cell:nth-child(11) { animation-delay: 0.55s; }
.heatmap-cell:nth-child(12) { animation-delay: 0.6s; }

@keyframes cellFadeIn {
  from { opacity: 0; transform: scale(0.7); }
  to { opacity: 1; transform: scale(1); }
}

.heatmap-cell-hover {
  transform: scale(1.08);
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

.heatmap-cell.level-0 { background: rgba(15, 52, 96, 0.3); }
.heatmap-cell.level-1 { background: rgba(233, 69, 96, 0.25); }
.heatmap-cell.level-2 { background: rgba(233, 69, 96, 0.45); }
.heatmap-cell.level-3 { background: rgba(233, 69, 96, 0.7); }
.heatmap-cell.level-4 {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.4);
}

.cell-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

/* ========== \u7a7a\u72b6\u6001\u5f15\u5bfc ========== */

.empty-participants {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
  text-align: center;
}

.empty-share-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

.empty-share-btn::after { display: none; }

/* ========== \u53c2\u4e0e\u8005\u5217\u8868 ========== */

.participants-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.participants-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.participant-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.participant-card:active {
  background: rgba(15, 52, 96, 0.6);
  transform: scale(0.98);
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.participant-avatar.small {
  width: 48rpx;
  height: 48rpx;
  font-size: 22rpx;
}

.participant-info { flex: 1; }

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 4rpx;
}

.participant-slots {
  font-size: 24rpx;
  color: var(--text-muted);
}

.participant-badge { font-size: 24rpx; }

/* ========== \u64cd\u4f5c\u6309\u94ae ========== */

.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(26, 26, 46, 0.98), transparent);
  display: flex;
  gap: 20rpx;
}

.share-btn,
.vote-btn,
.notify-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.share-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.share-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
}

.vote-btn {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
}

.vote-btn:active {
  transform: scale(0.98);
}

.notify-btn {
  width: 100%;
  margin-bottom: 16rpx;
  background: linear-gradient(135deg, #f59e0b, #f97316);
  color: #fff;
}

.notify-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.notify-btn.notifying {
  opacity: 0.7;
}

.btn-icon { font-size: 28rpx; }

/* ========== \u521b\u5efa\u6210\u529f\u63d0\u793a ========== */

.created-tip {
  position: fixed;
  top: 32rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
}

.tip-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: rgba(74, 222, 128, 0.15);
  border: 2rpx solid rgba(74, 222, 128, 0.3);
  border-radius: 16rpx;
}

.tip-icon { font-size: 32rpx; }

.tip-text {
  font-size: 26rpx;
  color: #4ade80;
}

/* ========== \u65f6\u6bb5\u8be6\u60c5\u5f39\u7a97 - Scale \u5165\u573a ========== */

.slot-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.slot-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 70vh;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%) scale(0.9);
  opacity: 0;
  transition: transform 0.35s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.3s ease;
}

.slot-modal.show .modal-content {
  transform: translateY(0) scale(1);
  opacity: 1;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.modal-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-count {
  font-size: 26rpx;
  color: var(--primary-light);
  background: rgba(233, 69, 96, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
}

.modal-close {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.modal-body {
  max-height: 50vh;
  overflow-y: auto;
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.no-data {
  text-align: center;
  padding: 48rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}
