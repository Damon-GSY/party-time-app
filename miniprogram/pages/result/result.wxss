/* 统计结果页面样式 - 热力图动画版 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(160deg, #1a1a2e 0%, #16213e 40%, #0f3460 100%);
  padding-bottom: 180rpx;
}

/* 淡入动画 */
.fade-in {
  animation: fadeInUp 0.5s ease forwards;
  opacity: 0;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 滑入动画 */
.slide-in {
  animation: slideIn 0.4s ease forwards;
  opacity: 0;
}

@keyframes slideIn {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

/* 加载状态 */
.loading-screen {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.loading-animation {
  position: relative;
  width: 100rpx;
  height: 100rpx;
}

.loading-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid transparent;
  border-top-color: var(--primary-color);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-ring:nth-child(2) {
  width: 70%;
  height: 70%;
  top: 15%;
  left: 15%;
  border-top-color: var(--primary-light);
  animation-duration: 0.7s;
  animation-direction: reverse;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 28rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 头部信息 */
.header-section {
  padding: 32rpx;
}

.event-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.event-name {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  flex: 1;
}

.event-badges {
  display: flex;
  gap: 12rpx;
}

.badge {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(74, 222, 128, 0.15);
  color: #4ade80;
}

.badge.expired {
  background: rgba(239, 68, 68, 0.15);
  color: #ef4444;
}

.event-meta {
  margin-bottom: 12rpx;
}

.meta-item {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.event-note {
  font-size: 24rpx;
  color: var(--text-muted);
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  margin-top: 12rpx;
}

/* 统计卡片 */
.stats-cards {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  flex: 1;
  padding: 28rpx;
  background: rgba(15, 52, 96, 0.5);
  border-radius: 20rpx;
  text-align: center;
  border: 2rpx solid rgba(255, 255, 255, 0.08);
}

.stat-value {
  margin-bottom: 8rpx;
}

.stat-number {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 最佳时段推荐 - 醒目卡片 */
.recommend-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.recommend-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 32rpx;
  border-radius: 24rpx;
}

.recommend-card.recommend-highlight {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.2), rgba(251, 191, 36, 0.08));
  border: 2rpx solid rgba(251, 191, 36, 0.4);
  box-shadow: 0 8rpx 32rpx rgba(251, 191, 36, 0.15);
}

.recommend-card.recommend-empty {
  background: linear-gradient(135deg, rgba(107, 107, 128, 0.15), rgba(107, 107, 128, 0.05));
  border: 2rpx solid rgba(107, 107, 128, 0.2);
}

.recommend-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.recommend-trophy {
  font-size: 56rpx;
  animation: trophy-bounce 2s ease-in-out infinite;
}

@keyframes trophy-bounce {
  0%, 100% { transform: translateY(0) rotate(-5deg); }
  50% { transform: translateY(-8rpx) rotate(5deg); }
}

.recommend-empty-icon {
  font-size: 48rpx;
  animation: float-emoji 3s ease-in-out infinite;
}

@keyframes float-emoji {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

.recommend-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.recommend-label {
  font-size: 22rpx;
  color: #fbbf24;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.recommend-card.recommend-empty .recommend-label {
  color: var(--text-secondary);
}

.recommend-time {
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8rpx;
}

.recommend-meta {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.recommend-count {
  font-size: 26rpx;
  color: #fbbf24;
  font-weight: 600;
}

.recommend-percent {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.recommend-hint {
  font-size: 24rpx;
  color: var(--text-muted);
  margin-top: 4rpx;
}

/* 热力图 */
.heatmap-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
}

/* 清晰图例条 */
.legend-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 16rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
}

.legend-label {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.legend-gradient {
  display: flex;
  flex: 1;
  gap: 4rpx;
}

.legend-step {
  flex: 1;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
}

.legend-value {
  font-size: 20rpx;
  font-weight: 600;
  color: #fff;
}

.legend-hint {
  font-size: 20rpx;
  color: var(--text-muted);
  flex-shrink: 0;
}

/* 日期标签 */
.date-labels {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding-left: 64rpx;
}

.date-label {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 16rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 12rpx;
}

.label-weekday {
  font-size: 20rpx;
  color: var(--text-muted);
}

.label-day {
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
}

/* 热力图主体 */
.heatmap-wrapper {
  display: flex;
  gap: 12rpx;
}

.time-column {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.time-text {
  height: 80rpx;
  font-size: 20rpx;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  justify-content: center;
}

.heatmap-grid {
  flex: 1;
  display: flex;
  gap: 12rpx;
}

.heatmap-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

/* 热力格子 - 加大尺寸 */
.heatmap-cell {
  height: 80rpx;
  min-height: 80rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  cursor: pointer;
  position: relative;
}

.heatmap-cell-hover {
  transform: scale(1.08);
  z-index: 10;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
}

/* 热力等级 - 更明显的颜色对比 */
.heatmap-cell.level-0 {
  background: rgba(15, 52, 96, 0.3);
}

.heatmap-cell.level-1 {
  background: rgba(233, 69, 96, 0.25);
}

.heatmap-cell.level-2 {
  background: rgba(233, 69, 96, 0.45);
}

.heatmap-cell.level-3 {
  background: rgba(233, 69, 96, 0.7);
}

.heatmap-cell.level-4 {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  box-shadow: 0 4rpx 16rpx rgba(233, 69, 96, 0.4);
}

.cell-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #fff;
}

/* 空状态 */
.empty-participants {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx;
  margin: 0 32rpx;
  background: rgba(255, 255, 255, 0.03);
  border-radius: 24rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.1);
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-bottom: 32rpx;
  text-align: center;
}

.empty-share-btn {
  padding: 20rpx 48rpx;
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  border-radius: 20rpx;
  font-size: 28rpx;
  color: #fff;
  border: none;
}

.empty-share-btn::after {
  display: none;
}

/* 参与者列表 */
.participants-section {
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.participants-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.participant-card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 24rpx;
  background: rgba(15, 52, 96, 0.4);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.participant-card:active {
  background: rgba(15, 52, 96, 0.6);
  transform: scale(0.98);
}

.participant-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  flex-shrink: 0;
}

.participant-avatar.small {
  width: 48rpx;
  height: 48rpx;
  font-size: 22rpx;
}

.participant-info {
  flex: 1;
}

.participant-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #fff;
  display: block;
  margin-bottom: 4rpx;
}

.participant-slots {
  font-size: 24rpx;
  color: var(--text-muted);
}

.participant-badge {
  font-size: 24rpx;
}

/* 操作按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, rgba(26, 26, 46, 0.98), transparent);
  display: flex;
  gap: 20rpx;
}

.share-btn,
.vote-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
}

.share-btn {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.share-btn:active {
  background: rgba(255, 255, 255, 0.15);
  transform: scale(0.98);
}

.vote-btn {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
  color: #fff;
}

.vote-btn:active {
  transform: scale(0.98);
}

.btn-icon {
  font-size: 28rpx;
}

/* 创建成功提示 */
.created-tip {
  position: fixed;
  top: 32rpx;
  left: 32rpx;
  right: 32rpx;
  z-index: 100;
}

.tip-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: rgba(74, 222, 128, 0.15);
  border: 2rpx solid rgba(74, 222, 128, 0.3);
  border-radius: 16rpx;
}

.tip-icon {
  font-size: 32rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #4ade80;
}

/* 时段详情弹窗 */
.slot-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: flex-end;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
}

.slot-modal.show {
  opacity: 1;
  visibility: visible;
}

.modal-backdrop {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: relative;
  width: 100%;
  max-height: 70vh;
  background: var(--bg-card);
  border-radius: 32rpx 32rpx 0 0;
  padding: 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  transform: translateY(100%);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
}

.slot-modal.show .modal-content {
  transform: translateY(0);
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.modal-header-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.modal-count {
  font-size: 26rpx;
  color: var(--primary-light);
  background: rgba(233, 69, 96, 0.15);
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
}

.modal-close {
  background: none;
  border: none;
  color: var(--text-secondary);
  font-size: 40rpx;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.2s ease;
}

.modal-close:active {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.modal-body {
  max-height: 50vh;
  overflow-y: auto;
}

.participant-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.participant-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
}

.no-data {
  text-align: center;
  padding: 48rpx;
  color: var(--text-muted);
  font-size: 28rpx;
}
