<!--通知中心页面-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-icon">🔔</view>
    <view class="header-title">通知中心</view>
    <view class="header-desc">查看最近的提醒记录</view>
  </view>

  <!-- 通知列表 -->
  <view class="notification-list" wx:if="{{notifications.length > 0}}">
    <view
      class="notification-item {{item.read ? 'read' : 'unread'}}"
      wx:for="{{notifications}}"
      wx:key="id"
      bindtap="markAsRead"
      data-id="{{item.id}}"
    >
      <view class="notification-icon">{{item.icon}}</view>
      <view class="notification-content">
        <view class="notification-title">{{item.title}}</view>
        <view class="notification-desc">{{item.description}}</view>
        <view class="notification-time">{{item.timeText}}</view>
      </view>
      <view class="notification-badge" wx:if="{{!item.read}}"></view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <view class="empty-icon">📭</view>
    <view class="empty-text">暂无通知</view>
    <view class="empty-hint">当有人参与你的聚会或活动即将过期时，会收到提醒</view>
  </view>

  <!-- 底部操作 -->
  <view class="footer-actions" wx:if="{{notifications.length > 0}}">
    <view class="clear-btn" bindtap="clearAll">清空通知</view>
  </view>
</view>
